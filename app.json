{
  "expo": {
    "name": "AyurTwin",
    "slug": "ayurtwin",
    "version": "1.0.0",
    "orientation": "portrait",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayurtwin.app"
    },
    "android": {
      "package": "com.ayurtwin.app"
    },
    "web": {},
    "plugins": [
      "expo-notifications",
      "expo-local-authentication",
      "expo-sensors"
    ]
  }
}
