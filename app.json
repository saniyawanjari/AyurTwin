{
  "expo": {
    "name": "AyurTwin",
    "slug": "ayurtwin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayurtwin.app"
    },
    "android": {
      "package": "com.ayurtwin.app"
    },
    "plugins": [
      "expo-notifications",
      "expo-local-authentication",
      "expo-sensors"
      
    ]
  }
}